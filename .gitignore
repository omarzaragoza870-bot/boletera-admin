# ============================================================
#  .gitignore — boletera-admin
#  Va en la RAÍZ del repo (junto a backend/ y frontend/).
# ============================================================

# --- Dependencias de Node ---
# Una sola línea ignora node_modules en CUALQUIER carpeta
# (raíz, backend/, frontend/, etc.). No hay que reinstalarlas
# en el repo: se reconstruyen con "npm install".
node_modules/

# --- Variables de entorno y secretos ---
# NUNCA subir claves, tokens ni credenciales a GitHub.
.env
.env.*
!.env.example

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Carpetas de build / salida ---
dist/
build/
.cache/

# --- Basura del sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Configuración de editores ---
.vscode/
.idea/
*.swp

# --- Cobertura de tests / temporales ---
coverage/
tmp/
temp/

# ============================================================
#  OPCIONAL — descoméntalo solo si NO quieres versionar la
#  base de datos local (tus datos reales irían a GitHub).
#  Si la usas como "base inicial" de ejemplo, déjalo comentado.
# ============================================================
# database/db.json

# --- Archivos subidos por usuarios (imagenes, documentos) ---
database/uploads/